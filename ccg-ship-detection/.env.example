# ============================================================
# CCG Ship Detection - 環境變數設定
# 中共海警船偵測 - API 金鑰與認證資訊
# ============================================================
# 複製此檔案為 .env 並填入您的 API 金鑰:
#   cp .env.example .env
# ============================================================

# --- Copernicus Data Space Ecosystem (CDSE) ---
# 免費註冊: https://dataspace.copernicus.eu/
# 提供 Sentinel-1 (SAR) 和 Sentinel-2 (光學) 衛星影像
CDSE_USERNAME=your_email@example.com
CDSE_PASSWORD=your_password

# --- Planet Labs ---
# 商業服務，需申請帳號: https://www.planet.com/
# 提供 3m 解析度每日重訪影像
PLANET_API_KEY=your_planet_api_key

# --- SkyFi ---
# 商業服務，多源衛星影像聚合平台: https://www.skyfi.com/
# 提供多家衛星供應商的影像（含 Maxar 0.3m）
SKYFI_API_KEY=your_skyfi_api_key

# --- Maxar ---
# 商業服務，最高解析度 (0.3m): https://www.maxar.com/
MAXAR_API_KEY=your_maxar_api_key
